{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -e '.prompt | test(\"^\\\\s*source\\\\s+\\\\S*venv\\\\S*/bin/activate\\\\s*$\")' >/dev/null && printf '%s' '{\"decision\":\"block\",\"reason\":\"ignored VS Code Python extension auto-activate injection\",\"suppressOutput\":true}' || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"Check this edit against ~/.claude/CLAUDE.md.\"}}'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/zsh/custom/claude-statusline"
  },
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "medium"
}
